pipeline {
  agent none
  stages {
    stage('Checkout') {
      agent {
        docker { image 'maven:3-openjdk-17' }
      }
      steps {
        git branch: 'main',
        url: 'https://github.com/j0chan/jyc-source-maven-java-spring-hello-webapp.git'
      }
    }
    stage('Build') {
      agent {
        docker { image 'maven:3-openjdk-17' }
      }
      steps {
        sh 'mvn clean package -DskipTests=true'
      }
    }
    stage('Test') {
      agent {
        docker { image 'maven:3-openjdk-17' }
      }
      steps {
        sh 'mvn test'
      }
    }
    stage('Build Docker Image') {
      agent { label 'controller' }
      steps {
        sh 'docker image build -t jyc00000/tomcat:v$BUILD_NUMBER .'
      }
    }
    stage('Docker Image Tag') {
      agent { label 'controller' }
      steps {
        sh 'docker image tag jyc00000/tomcat:v$BUILD_NUMBER jyc00000/tomcat:latest'
      }
    }
    stage('Publish Docker Image') {
      agent { label 'controller' }
      steps {
        withDockerRegistry(credentialsId: 'docker-registry-credential', url: 'https://index.docker.io/v1/') {
          sh 'docker image push jyc00000/tomcat:v$BUILD_NUMBER'
          sh 'docker image push jyc00000/tomcat:latest'
        }
      }
    }
    stage('Run Docker Container') {
      agent { label 'controller' }
      steps {
        ansiblePlaybook(playbook: 'docker-container-deploy.yaml')
      }
    }
  }
}

